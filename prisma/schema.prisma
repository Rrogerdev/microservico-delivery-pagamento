generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_PAGAMENTOS_URL")
}

model pagamentos {
  pagamento_id       Int                  @id @unique(map: "idpagamento_id_UNIQUE") @default(autoincrement())
  pagamento_status   Int                  @default(1)
  pedido_id          Int
  cupom_id           Int?
  pagamentos_data    DateTime             @db.DateTime(0)
  pagamentos_valor   Decimal?             @db.Decimal(10, 2)
  pagamento_detalhes pagamento_detalhes[]
  cupons             cupons?              @relation(fields: [cupom_id], references: [cupom_id], onDelete: NoAction, onUpdate: NoAction, map: "cupom_id")

  @@index([cupom_id], map: "cupom_id_idx")
  @@map("pagamentos")
}

model pagamento_detalhes {
  pagamento_detalhes_id         Int        @id @default(autoincrement())
  pagamento_detalhes_produto_id Int?
  pagamento_detalhes_quantidade Int
  pagamentos_id                 Int
  pagamentos                    pagamentos @relation(fields: [pagamentos_id], references: [pagamento_id], onDelete: NoAction, onUpdate: NoAction, map: "pagamentos_id")

  @@index([pagamentos_id], map: "pagamentos_id_idx")
}

model cupons {
  cupom_id       Int          @id @unique(map: "cupom_id_UNIQUE") @default(autoincrement())
  cupom_codigo   String       @unique(map: "cupom_codigo_UNIQUE") @db.VarChar(45)
  cupom_desconto Decimal      @default(0.00) @db.Decimal(10, 2)
  cupom_status   Int          @default(1)
  pagamentos     pagamentos[]
}
